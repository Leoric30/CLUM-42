# ══════════════════════════════════════════════════════════════
# CLUM — Variables de entorno de producción
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ══════════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ──────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=

# ── JWT (mínimo 32 caracteres, HS256) ─────────────────────────
JWT_SECRET=

# ── AWS S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# ── Inscripción: contraseña temporal de aspirantes ────────────
ENROLLMENT_TEMP_PASSWORD=
